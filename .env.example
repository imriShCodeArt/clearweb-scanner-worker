PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Required. Use at least 32 random characters in production:
# openssl rand -hex 32
API_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Optional. When set, GET /api/metrics requires the same Bearer / X-Api-Key auth.
METRICS_API_KEY=

# Set to 1 (or true) when running behind nginx/Caddy/Cloudflare.
TRUST_PROXY=

SCAN_TIMEOUT_MS=30000
SCAN_NAVIGATION_TIMEOUT_MS=
MAX_CONCURRENT_SCANS=2
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
JOB_RETENTION_MS=3600000
SHUTDOWN_DRAIN_MS=30000
SENTRY_DSN=
LOG_LEVEL=debug
PLAYWRIGHT_HEADLESS=true

# Docker Compose — host bind address and published port (container always listens on 3000).
BIND_HOST=127.0.0.1
HOST_PORT=3000

# docker-compose.prod.yml — image tag from GHCR (default: latest)
IMAGE_TAG=latest
